# NeuroStudy — exemplo de variáveis de ambiente
# Nunca coloque valores reais/secrets neste arquivo.

# URL pública usada em redirects/callbacks
PUBLIC_SITE_URL=https://neurostudy.com.br

# Origens permitidas para CORS, separadas por vírgula
# Padrão do código já inclui neurostudy.com.br, www e localhost
CORS_ALLOWED_ORIGINS=https://neurostudy.com.br,https://www.neurostudy.com.br,http://localhost:5173

# Monitoramento de erros backend
# Deixe vazio para desabilitar localmente
SENTRY_DSN=

# Supabase — backend/serverless
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DIAGRAMS_BUCKET=diagrams

# Vertex/Gemini
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_ROUTER=gemini-3.1-flash-lite
GEMINI_MODEL_EXPERIMENTAL=gemini-3.1-pro-preview
GEMINI_MODEL_PRO_FALLBACK=gemini-2.5-pro
GEMINI_3_VERTEX_LOCATION=global
GEMINI_3_API_VERSION=v1beta
DEBUG_MODEL_LOGS=0

# Chat/Professor Virtual — opcionais
GEMINI_CHAT_HISTORY_MAX=10
GEMINI_CHAT_MSG_MAX_CHARS=900
GEMINI_CHAT_SYSTEM_EXTRA=

# Suporte por e-mail
SUPPORT_EMAIL=contato@neurostudy.com.br
ZEPTOMAIL_TOKEN=
ZEPTOMAIL_FROM_EMAIL=
ZEPTOMAIL_FROM_NAME=NeuroStudy

# Pagamentos — Asaas
ASAAS_ENV=production
ASAAS_API_BASE=
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

# Pagamentos legados — Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=

# Uso/limites
USAGE_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

# Desenvolvimento local apenas
# Só funciona com NODE_ENV !== 'production'. NUNCA habilite em produção.
ENABLE_DEV_AUTH_HEADER=false

# Debug opcional
DEBUG_DIAGRAM_LOGS=0
